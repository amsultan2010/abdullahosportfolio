---
import '../../styles/global.css';
import { AstroSeo } from '@astrolib/seo';
---

<!-- Core meta tags -->
<meta charset='UTF-8' />
<meta http-equiv='X-UA-Compatible' content='IE=edge' />
<meta
  name='viewport'
  content='width=device-width, initial-scale=1, maximum-scale=1'
/>
<meta name='author' content='Abdullah Sultan' />
<!-- student builder -->

<!-- SEO Configuration - customize these values -->
<AstroSeo
  title={Astro.props.title || 'Abdullah Sultan - student builder'}
  description={Astro.props.description ||
    'student builder based in Riyadh, Saudi Arabia specializing in systematic trading strategies and scalable infrastructure'}
  canonical={Astro.props.canonical || 'https://github.com/amsultan2010'}
  openGraph={{
    url: Astro.props.openGraph?.url || 'https://github.com/amsultan2010',
    title: Astro.props.openGraph?.title || 'Abdullah Sultan - student builder',
    description:
      Astro.props.openGraph?.description ||
      'student builder based in Riyadh, Saudi Arabia specializing in systematic trading strategies and scalable infrastructure',
    images: [
      {
        url: '',
        // og image here
      },
    ],
    site_name: Astro.props.openGraph?.site_name || 'Abdullah Sultan',
  }}
/>

<!-- Optimized favicon -->
<link rel='apple-touch-icon' sizes='180x180' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='152x152' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='144x144' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='120x120' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='114x114' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='76x76' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='72x72' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='60x60' href='/icons/abdullah-apple-touch.png' />
<link rel='apple-touch-icon' sizes='57x57' href='/icons/abdullah-apple-touch.png' />
<link
  rel='icon'
  type='image/png'
  sizes='96x96'
  href='/icons/abdullah-favicon.png'
/>
<link
  rel='icon'
  type='image/png'
  sizes='32x32'
  href='/icons/abdullah-favicon.png'
/>
<link
  rel='icon'
  type='image/png'
  sizes='16x16'
  href='/icons/abdullah-favicon.png'
/>
<link rel='shortcut icon' href='/icons/abdullah-favicon.png' />

<!-- Theme colors for browsers -->
<meta name='msapplication-TileColor' content='#1e293b' />
<meta name='theme-color' content='#1e293b' />

<!-- Auto-generated sitemap -->
<link rel='sitemap' href='/sitemap-index.xml' />

<!-- Preload background images for performance -->
<link
  rel='preload'
  href='/images/wallpaper/wallpaper.jpg'
  as='image'
  type='image/jpeg'
  fetchpriority='high'
/>
