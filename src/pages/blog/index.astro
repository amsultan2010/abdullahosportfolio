---
export const prerender = false;
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { getRecentBlogPosts } from '../../utils/blog';
import { getFixedBackgroundKey, getOptimizedBackgrounds } from '../../utils/backgrounds';
import Nav from '../../components/global/Nav';
import MobileDock from '../../components/global/MobileDock';
import DesktopDock from '../../components/global/DesktopDock';
import Background from '../../components/portfolio/Background';

const posts = await getCollection('blog', ({ id }) => {
  return !id.startsWith('_archive/');
});
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Get optimized backgrounds
const backgroundMap = await getOptimizedBackgrounds(getImage);

// Fetch recent blog posts for navigation
const recentPosts = await getRecentBlogPosts();

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title='Blog - Abdullah Sultan'
  description='education, activities, and school work from Abdullah Sultan'
  canonical='https://github.com/amsultan2010'
>
  <div class="relative w-screen min-h-screen">
    <!-- WebGL Background -->
    <Background client:only="react" />

    <!-- Navbar -->
    <div class="relative z-10">
      <Nav client:load currentPath="/blog" recentPosts={recentPosts} />
    </div>

    <!-- Main Content -->
    <div class="relative pt-12 pb-32 px-4">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12 mt-8 flex justify-center">
          <div class="glass rounded-lg p-6">
            <h1 class="text-base font-bold text-white mb-2 font-mono">
              <span class="text-green-400">$</span> cd ~/education
            </h1>
            <p class="text-gray-300 font-mono text-sm">
              education, activities, and school work.
            </p>
          </div>
        </div>

        <!-- Blog Posts Grid -->
        <div class="grid gap-6">
          {sortedPosts.map((post) => (
            <a
              href={`/blog/${post.data.slug || post.slug}`}
              class="glass-pane rounded-lg overflow-hidden shadow-2xl hover:shadow-3xl transition-all duration-300 group"
            >
              <div class="h-6 flex items-center space-x-2 px-4 border-b border-white/10">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="text-sm text-gray-200 flex-grow text-center font-semibold">
                  {post.data.slug || post.slug}.blog
                </span>
              </div>

              <div class="p-6 lg:p-8">
                <!-- Title -->
                <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3 font-mono group-hover:text-green-400 transition-colors">
                  {post.data.title}
                </h2>

                <!-- Metadata -->
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400 font-mono mb-4">
                  <span>{formatDate(post.data.publishedAt)}</span>
                  {post.data.readingTime && (
                    <>
                      <span class="text-gray-600">•</span>
                      <span>{post.data.readingTime} min read</span>
                    </>
                  )}
                </div>

                <!-- Summary -->
                <p class="text-gray-300 mb-4 leading-relaxed">
                  {post.data.summary}
                </p>

                <!-- Tags -->
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="tag-list flex flex-wrap gap-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="pill">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}

                <!-- Read More Indicator -->
                <div class="mt-4 flex items-center text-green-400 font-mono text-sm group-hover:translate-x-2 transition-transform">
                  <span>Read post</span>
                  <span class="ml-2">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Empty State -->
        {sortedPosts.length === 0 && (
          <div class="text-center py-12">
            <div class="glass rounded-lg p-8 inline-block">
              <p class="text-gray-300 font-mono">
                <span class="text-green-400">$</span> ls -la
                <br />
                <span class="text-gray-500">No posts yet. Check back soon!</span>
              </p>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Docks -->
    <MobileDock client:load />
    <DesktopDock client:load />
  </div>
</Layout>

<style>
  :global(body) {
    background-color: #000 !important;
  }
</style>
